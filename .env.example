# ─────────────────────────────────────────────
#  WAIQ News — Variables de entorno
#  Copia este archivo como .env y rellena los valores
#  NUNCA subas .env al repositorio
# ─────────────────────────────────────────────

# ── MailerLite ────────────────────────────────
MAILERLITE_API_KEY=your_mailerlite_api_key
MAILERLITE_GROUP_ID=your_group_id

# ── Remitente del email ───────────────────────
FROM_NAME=#WAIQ
FROM_EMAIL=hello@waiq.technology

# ── Endpoints Hugo (servidor en producción) ───
# Endpoint para modo single: devuelve markdown+frontmatter del post con radar:true más reciente
HUGO_SINGLE_ENDPOINT=https://waiq.technology/api/newsletter/single

# Endpoint para modo digest: devuelve {button_urls: [...], total: N}
# Se le pasa ?since=YYYY-MM-DD como query param
HUGO_DIGEST_ENDPOINT=https://waiq.technology/api/newsletter/digest

# ── Sitio ─────────────────────────────────────
SITE_BASE_URL=https://waiq.technology

# ── Anthropic (para generación editorial del digest) ──
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Comportamiento ────────────────────────────
# Modo de ejecución: single | digest
MODE=single

# Solo para modo digest: fecha desde la que recuperar artículos (YYYY-MM-DD)
# En GitHub Actions se pasa como input; en local se puede fijar aquí
SINCE_DATE=2026-03-01

# Si es "true" genera el HTML y lo imprime pero NO envía la campaña
DRY_RUN=false
