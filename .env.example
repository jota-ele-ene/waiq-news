# ─────────────────────────────────────────────
#  WAIQ News — Variables de entorno
#  Copia como .env y rellena los valores
#  NUNCA subas .env al repositorio
# ─────────────────────────────────────────────

# ── Brevo ─────────────────────────────────────
# API key: app.brevo.com → Settings → API Keys
BREVO_API_KEY=your_brevo_api_key
# ID numérico de la lista (columna ID en Contacts → Lists)
BREVO_LIST_ID=your_list_id_number
# ID de plantilla wrapper (vacío = HTML autónomo)
# La plantilla debe tener {{ params.body | safe }} donde va el cuerpo
BREVO_TEMPLATE_ID=

# ── Remitente ──────────────────────────────────
FROM_NAME=#WAIQ
FROM_EMAIL=hello@waiq.technology

# ── Endpoints Hugo — single (devuelve markdown+frontmatter) ───────────────────
HUGO_SINGLE_ENDPOINT_ES=https://waiq.technology/es/api/newsletter/single
HUGO_SINGLE_ENDPOINT_EN=https://waiq.technology/api/newsletter/single

# ── Endpoints Hugo — digest (devuelve JSON con button_urls + articles) ────────
# El script añade el sufijo -15 o -30 según --days
# Ej: HUGO_DIGEST_ENDPOINT_ES + "-15" → https://waiq.technology/es/api/newsletter/digest-15
HUGO_DIGEST_ENDPOINT_ES=https://waiq.technology/es/api/newsletter/digest
HUGO_DIGEST_ENDPOINT_EN=https://waiq.technology/api/newsletter/digest

# ── Sitio ──────────────────────────────────────
SITE_BASE_URL=https://waiq.technology

# ── Anthropic (para generación editorial del digest) ─────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Comportamiento (se sobreescriben con flags CLI) ───────────────────────────
MODE=single          # single | digest
LANG=es              # es | en
DAYS=15              # 15 | 30  (solo digest)
DRY_RUN=false        # true = genera sin enviar
